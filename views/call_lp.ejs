<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>電話で希望条件を確認</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="lp">
  <main class="lpbox">
    <p class="eyebrow">以前ご登録いただいた方向け</p>
    <h1>ドライバー求人の希望条件を電話で確認します</h1>
    <p>今すぐ転職でなくても問題ありません。担当者が10分ほどお電話で希望条件を確認します。</p>
    <% if (!gasConfigured) { %>
      <div class="notice error">GAS_WEBAPP_URLが未設定です。</div>
    <% } %>
    <div class="choiceList">
      <% answers.forEach(function(answer) { %>
        <a class="choice" href="<%= answer.url %>"><%= answer.label %></a>
      <% }) %>
    </div>
  </main>
</body>
</html>
